# backend/.env.example
# Copy to .env and fill in real values. Never commit .env to git.

# App
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://copilot:copilot@localhost:5432/copilot_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — generate with: openssl rand -hex 64
JWT_SECRET_KEY=your-super-secret-key-here

# LLM — choose one
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o

# AWS S3 (for invoice storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=copilot-invoices
